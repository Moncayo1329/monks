---


---
<div x-data="{ mobileMenuOpen: false }">

<div class="max-w-7xl mx-auto  px-6 lg:px-10 py-6 flex items-center justify-between">


   
<a
href="/"
class="text-3xl font-bold text-orange-700 hover:text-orange-600  transition-colors duration-200">
Monks
</a>


<!--Menu --> 

<nav class="hidden md:flex w-full items-center justify-center gap-x-10 text-base font-medium">
<a href="/" class="text-white border-b-2 border-transparent hover:border-orange-500">Inicio</a>
<a href="/fotografias" class="text-white border-b-2 border-transparent hover:border-orange-500">Fotografías</a>
<a href="/noticias" class="text-white border-b-2 border-transparent hover:border-orange-500">Noticias</a>

 </nav>
<!-- boton -->
 <button 
      @click="mobileMenuOpen = !mobileMenuOpen"
      class="md:hidden text-orange-800 p-2 rounded-xl hover:bg-zinc-100 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

 </div>

 <!--menu mobile -->
 <div 
    x-show="mobileMenuOpen"
    class="md:hidden bg-transparent border-b"
    x-transition
  >
    <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col gap-y-6 text-lg font-medium">
      <a 
        href="/" 
        @click="mobileMenuOpen = false"
        class="text-white border-b-2 border-transparent active:border-orange-500"
      >
        Inicio
      </a>
      <a 
        href="/fotografias" 
        @click="mobileMenuOpen = false"
        class="text-white border-b-2 border-transparent active:border-orange-500"
      >
        Fotografias
      </a>
      <a 
        href="/noticias" 
        @click="mobileMenuOpen = false"
        class="text-white border-b-2 border-transparent active:border-orange-500"
      >
        Noticias
      </a>
    </div>
  </div>

</div>







