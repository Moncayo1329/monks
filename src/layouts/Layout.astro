---
import '../styles/global.css'
import Header from "../components/Header.astro"
import Footer from '../components/Footer.astro';
interface Props{
	title: string;
	description: string;
	image?:string;

}

const {title = "Baloncesto Monks", description ="Club de Baloncesto Monks", image ="/images/cover.jpeg" } = Astro.props;

// Google analytics 

const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;

---


<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
       <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
       <link href="https://fonts.googleapis.com/css2?family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&display=swap" rel="stylesheet">
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<link rel="icon" href="/public/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:image" content={image}/>
		<title>{title}</title>

<!-- google analytics --> 

{
            GA_ID && import.meta.env.PROD && (
                <>
                    <script 
                        is:inline 
						async
                        src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
                    ></script>
                    
                    <script is:inline define:vars={{ GA_ID }}>
                        window.dataLayer = window.dataLayer || [];
                        function gtag(){dataLayer.push(arguments);}
                        gtag('js', new Date());
                        gtag('config', GA_ID);
                    </script>
                </>
            )
        }



		<style>
    body {
      background-image: 
        linear-gradient(rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0.65)), 
        url('/Photos/cover.jpeg');  
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-attachment: fixed;   /* opcional: fondo fijo al hacer scroll */
      min-height: 100vh;
    }
  </style>
	</head>
	<body class="min-h-screen bg-[#1a2428] text-white">
		<Header/>
		<slot />
		<Footer />
	</body>
</html>

