---
import '../styles/global.css'
import Header from "../components/Header.astro"
interface Props{
	title: string;
	description: string;
	image?:string;

}

const {title = "Baloncesto Monks", description ="Club de Baloncesto Monks", image ="/images/band.jpg" } = Astro.props;





---





<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:image" content={image}/>
		<title>{title}</title>
		<style>
    body {
      background-image: 
        linear-gradient(rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0.65)), 
        url('/src/Pictures/monkspicture.png');   /* ← cambia esta ruta */
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-attachment: fixed;   /* opcional: fondo fijo al hacer scroll */
      min-height: 100vh;
    }
  </style>
	</head>
	<body class="min-h-screen bg-[#1a2428] text-white">
		<Header/>
		<slot />
	</body>
</html>

